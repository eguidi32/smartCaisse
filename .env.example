# Configuration SmartCaisse
# Copiez ce fichier en .env et remplissez vos valeurs

# ============================================
# SÉCURITÉ - CRITIQUE
# ============================================

# Clé secrète pour sessions, CSRF, tokens
# ⚠️ GÉNÉRER UNE CLÉ UNIQUE EN PRODUCTION avec:
#    python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire-64-caracteres-minimum

# Mode Flask (development ou production)
FLASK_ENV=development

# Configuration Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application
MAIL_DEFAULT_SENDER=SmartCaisse <votre-email@gmail.com>

# Base de données (optionnel, SQLite par défaut)
# DATABASE_URL=sqlite:///instance/smartcaisse.db

# ============================================
# LOGGING (optionnel)
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/smartcaisse.log
