# SmartCaisse - exemple .env pour Oracle Cloud Always Free
# Copier ce fichier vers /opt/smartcaisse/.env puis remplacer les valeurs.

FLASK_ENV=production
SECRET_KEY=remplacer-par-une-cle-generee-avec-python-secrets

# Premiere mise en ligne sans certificat:
# FORCE_HTTPS=false
# Apres Certbot/HTTPS:
# FORCE_HTTPS=true
FORCE_HTTPS=false
TRUST_PROXY_HEADERS=true

BASE_URL=http://votre-ip-ou-domaine
DATABASE_URL=sqlite:////opt/smartcaisse/instance/smartcaisse.db

LOG_LEVEL=INFO
LOG_FILE=/opt/smartcaisse/logs/smartcaisse.log

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application
MAIL_DEFAULT_SENDER=SmartCaisse <votre-email@gmail.com>
