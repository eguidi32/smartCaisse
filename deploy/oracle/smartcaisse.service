[Unit]
Description=SmartCaisse Flask application
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/smartcaisse
EnvironmentFile=/opt/smartcaisse/.env
ExecStart=/opt/smartcaisse/venv/bin/gunicorn --workers 1 --threads 4 --timeout 120 --bind 127.0.0.1:8000 --access-logfile - --error-logfile - wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
